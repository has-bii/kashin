// ============================================================
// Prisma Schema — AI Expense & Income Tracker
// Prisma 7 | PostgreSQL
// Auth: Better Auth (user, session, account, verification)
// PK strategy: UUID v7 for user-facing tables,
//              BigInt AUTO_INCREMENT for internal tables
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator prismabox {
  provider                    = "prismabox"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
  inputModel                  = true
  output                      = "../src/generated/prismabox"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------
// Enums
// -----------------------------------------------------------

enum TransactionType {
  expense
  income
}

enum TransactionSource {
  manual
  email
  recurring
}

enum RecurringFrequency {
  weekly
  biweekly
  monthly
  yearly
}

enum BudgetPeriod {
  daily
  weekly
  monthly
}

enum AiExtractionStatus {
  pending
  processing
  rejected
  waitingApproval
  confirmed
  failed
}

// -----------------------------------------------------------
// Better Auth tables (do not modify)
// -----------------------------------------------------------

model User {
  id            String    @id @default(uuid(7)) @db.Uuid
  name          String    @db.VarChar(255)
  email         String    @db.VarChar(255)
  emailVerified Boolean   @default(false)
  image         String?   @db.Text
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
  sessions      Session[]
  accounts      Account[]
  passkeys      Passkey[]

  // App relations
  categories            Category[]
  transactions          Transaction[]
  aiExtractions         AiExtraction[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]
  bankAccounts          BankAccount[]
  settings              UserSettings?
  gmailWatchConfig      GmailWatchConfig?
  @@unique([email])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid(7)) @db.Uuid
  expiresAt DateTime
  token     String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid(7)) @db.Uuid
  accountId             String    @db.VarChar(255)
  providerId            String    @db.VarChar(255)
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.VarChar(255)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid(7)) @db.Uuid
  identifier String   @db.VarChar(255)
  value      String   @db.VarChar(255)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Passkey {
  id           String    @id @default(uuid(7)) @db.Uuid
  name         String?   @db.VarChar(255)
  publicKey    String    @db.Text
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String    @db.Uuid
  credentialID String    @db.Text
  counter      Int
  deviceType   String    @db.VarChar(100)
  backedUp     Boolean
  transports   String?   @db.Text
  createdAt    DateTime? @db.Timestamptz()
  aaguid       String?   @db.Text

  @@map("passkey")
}

model UserSettings {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @unique @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_settings")
}

model GmailWatchConfig {
  id              String    @id @default(uuid(7)) @db.Uuid
  userId          String    @unique @db.Uuid
  gmailAddress    String    @db.VarChar(255)
  enabled         Boolean   @default(false)
  historyId       String?   @db.VarChar(50)
  expiresAt       DateTime? @db.Timestamptz
  qstashMessageId String?   @db.Text
  subjectKeywords String[]  @default([]) @db.VarChar(255)
  gmailLabels     String[]  @default([]) @db.VarChar(100)
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @updatedAt @db.Timestamptz

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankFilters GmailWatchBankFilter[]

  @@index([userId])
  @@index([gmailAddress])
  @@map("gmail_watch_configs")
}

model GmailWatchBankFilter {
  id            String @id @default(uuid(7)) @db.Uuid
  watchConfigId String @db.Uuid
  bankAccountId String @db.Uuid

  watchConfig GmailWatchConfig @relation(fields: [watchConfigId], references: [id], onDelete: Cascade)
  bankAccount BankAccount      @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@unique([watchConfigId, bankAccountId])
  @@map("gmail_watch_bank_filters")
}

// -----------------------------------------------------------
// App tables — User-facing (UUID v7, Char(36))
// -----------------------------------------------------------

model Category {
  id        String          @id @default(uuid(7)) @db.Uuid
  userId    String          @db.Uuid
  name      String          @db.VarChar(100)
  type      TransactionType
  icon      String          @db.VarChar(50)
  color     String          @db.Char(7)
  createdAt DateTime        @default(now()) @db.Timestamptz
  updatedAt DateTime        @updatedAt @db.Timestamptz

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  aiExtractions         AiExtraction[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]

  @@unique([name, userId])
  @@index([userId])
  @@index([userId, type])
  @@map("categories")
}

model Transaction {
  id              String            @id @default(uuid(7)) @db.Uuid
  userId          String            @db.Uuid
  categoryId      String?           @db.Uuid
  recurringTxnId  String?           @db.Uuid
  aiExtractionId  String?           @unique @db.Uuid
  bankAccountId   String?           @db.Uuid
  type            TransactionType
  amount          Decimal           @db.Decimal(15, 2)
  currency        String            @default("IDR") @db.Char(3)
  transactionDate DateTime          @db.Timestamptz
  description     String?           @db.VarChar(255)
  notes           String?           @db.Text
  source          TransactionSource @default(manual)
  createdAt       DateTime          @default(now()) @db.Timestamptz
  updatedAt       DateTime          @updatedAt @db.Timestamptz

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  category             Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurringTransaction RecurringTransaction? @relation(fields: [recurringTxnId], references: [id], onDelete: SetNull)
  aiExtraction         AiExtraction?         @relation(fields: [aiExtractionId], references: [id], onDelete: SetNull)
  bankAccount          BankAccount?          @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([categoryId])
  @@index([recurringTxnId])
  @@index([userId, transactionDate])
  @@index([userId, type])
  @@index([userId, categoryId])
  @@index([userId, source])
  @@index([bankAccountId])
  @@map("transactions")
}

model RecurringTransaction {
  id                String             @id @default(uuid(7)) @db.Uuid
  userId            String             @db.Uuid
  categoryId        String?            @db.Uuid
  type              TransactionType
  amount            Decimal            @db.Decimal(15, 2)
  currency          String             @default("IDR") @db.Char(3)
  description       String             @db.VarChar(255)
  frequency         RecurringFrequency
  nextDueDate       DateTime           @db.Timestamptz
  lastGeneratedDate DateTime?          @db.Timestamptz
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now()) @db.Timestamptz
  updatedAt         DateTime           @updatedAt @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([userId])
  @@index([categoryId])
  @@index([isActive, nextDueDate])
  @@map("recurring_transactions")
}

model Budget {
  id             String       @id @default(uuid(7)) @db.Uuid
  userId         String       @db.Uuid
  categoryId     String       @db.Uuid
  amount         Decimal      @db.Decimal(15, 2)
  period         BudgetPeriod
  alertThreshold Float        @default(0.8) @db.Real
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, period])
  @@index([userId])
  @@map("budgets")
}

model Bank {
  id             String   @id @default(uuid(7)) @db.Uuid
  name           String   @unique @db.VarChar(100)
  email          String[] @default([]) @db.VarChar(255)
  imageUrl       String
  isSupportEmail Boolean

  bankAccounts BankAccount[]

  @@map("banks")
}

model BankAccount {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @db.Uuid
  bankId    String   @db.Uuid
  balance   Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bank          Bank           @relation(fields: [bankId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  aiExtractions AiExtraction[]
  gmailWatchBankFilters GmailWatchBankFilter[]

  @@unique([userId, bankId])
  @@map("bank_accounts")
}

model AiExtraction {
  id                 String             @id @default(uuid(7)) @db.Uuid
  userId             String             @db.Uuid
  status             AiExtractionStatus @default(pending)
  // Email Data
  gmailMessageId  String             @unique @db.VarChar(255)
  emailFrom       String             @db.VarChar(255)
  emailSubject    String             @db.VarChar(255)
  emailSnippet    String             @db.VarChar(500)
  emailText       String?            @db.Text
  emailHtml       String?            @db.Text
  emailReceivedAt DateTime?          @db.Timestamptz

  // Extraction Data
  extractedType          TransactionType?
  extractedMerchant      String?          @db.VarChar(255)
  extractedAmount        Decimal?         @db.Decimal(15, 2)
  extractedCurrency      String?          @db.Char(3)
  extractedDate          DateTime?        @db.Timestamptz
  extractedCategoryId    String?          @db.Uuid
  extractedBankAccountId String?          @db.Uuid
  suggestedCategory      String?          @db.VarChar(255)
  confidenceScore        Float?           @db.Real
  errorMessage           String?          @db.Text
  note                   String?          @db.Text

  // Proces Timeline
  processedAt DateTime? @db.Timestamptz
  finishedAt  DateTime? @db.Timestamptz
  confirmedAt DateTime? @db.Timestamptz
  rejectedAt  DateTime? @db.Timestamptz

  // AI Process
  tokenUsage Int?
  aiResponse String? @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  extractedCategory    Category?         @relation(fields: [extractedCategoryId], references: [id], onDelete: SetNull)
  transaction          Transaction?
  extractedBankAccount BankAccount?      @relation(fields: [extractedBankAccountId], references: [id], onDelete: SetNull)

  @@index([extractedBankAccountId])
  @@index([extractedCategoryId])
  @@index([userId, status])
  @@map("ai_extractions")
}
