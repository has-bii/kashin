// ============================================================
// Prisma Schema — AI Expense & Income Tracker
// Prisma 7 | PostgreSQL
// Auth: Better Auth (user, session, account, verification)
// PK strategy: UUID v7 Char(36) for user-facing tables,
//              BigInt AUTO_INCREMENT for internal tables
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator prismabox {
  provider                    = "prismabox"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
  inputModel                  = true
  output                      = "../src/generated/prismabox"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------
// Enums
// -----------------------------------------------------------

enum TransactionType {
  expense
  income
}

enum TransactionSource {
  manual
  email
  recurring
}

enum EmailLogStatus {
  received
  processing
  parsed
  failed
}

enum AiExtractionStatus {
  pending
  confirmed
  rejected
  edited
}

enum RecurringFrequency {
  weekly
  biweekly
  monthly
  yearly
}

enum BudgetPeriod {
  daily
  weekly
  monthly
}

// -----------------------------------------------------------
// Better Auth tables (do not modify)
// -----------------------------------------------------------

model User {
  id            String    @id @default(uuid(7)) @db.Uuid
  name          String    @db.VarChar(255)
  email         String    @db.VarChar(255)
  emailVerified Boolean   @default(false)
  image         String?   @db.Text
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
  sessions      Session[]
  accounts      Account[]

  // App relations
  categories            Category[]
  transactions          Transaction[]
  emailInboxes          EmailInbox[]
  emailLogs             EmailLog[]
  aiExtractions         AiExtraction[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]
  bankAccounts          BankAccount[]

  @@unique([email])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid(7)) @db.Uuid
  expiresAt DateTime
  token     String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid(7)) @db.Uuid
  accountId             String    @db.VarChar(255)
  providerId            String    @db.VarChar(255)
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.VarChar(255)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid(7)) @db.Uuid
  identifier String   @db.VarChar(255)
  value      String   @db.VarChar(255)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// -----------------------------------------------------------
// App tables — User-facing (UUID v7, Char(36))
// -----------------------------------------------------------

model Category {
  id        String          @id @default(uuid(7)) @db.Uuid
  userId    String          @db.Uuid
  name      String          @db.VarChar(100)
  type      TransactionType
  icon      String          @db.VarChar(50)
  color     String          @db.Char(7)
  createdAt DateTime        @default(now()) @db.Timestamptz
  updatedAt DateTime        @updatedAt @db.Timestamptz

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  aiExtractions         AiExtraction[]         @relation("SuggestedCategory")
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]

  @@unique([name, userId])
  @@index([userId])
  @@index([userId, type])
  @@map("categories")
}

model Transaction {
  id              String            @id @default(uuid(7)) @db.Uuid
  userId          String            @db.Uuid
  categoryId      String?           @db.Uuid
  recurringTxnId  String?           @db.Uuid
  aiExtractionId  String?           @unique @db.Uuid
  bankAccountId   String?           @db.Uuid
  type            TransactionType
  amount          Decimal           @db.Decimal(15, 2)
  currency        String            @default("IDR") @db.Char(3)
  transactionDate DateTime          @db.Timestamptz
  description     String?           @db.VarChar(255)
  notes           String?           @db.Text
  source          TransactionSource @default(manual)
  createdAt       DateTime          @default(now()) @db.Timestamptz
  updatedAt       DateTime          @updatedAt @db.Timestamptz

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  category             Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurringTransaction RecurringTransaction? @relation(fields: [recurringTxnId], references: [id], onDelete: SetNull)
  aiExtraction         AiExtraction?         @relation(fields: [aiExtractionId], references: [id], onDelete: SetNull)
  bankAccount          BankAccount?          @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  attachments          Attachment[]

  @@index([userId])
  @@index([categoryId])
  @@index([recurringTxnId])
  @@index([userId, transactionDate])
  @@index([userId, type])
  @@index([userId, categoryId])
  @@index([userId, source])
  @@index([bankAccountId])
  @@map("transactions")
}

model EmailInbox {
  id           String   @id @default(uuid(7)) @db.Uuid
  userId       String   @db.Uuid
  emailAddress String   @unique @db.VarChar(255)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]

  @@index([userId])
  @@map("email_inboxes")
}

model AiExtraction {
  id                  String             @id @default(uuid(7)) @db.Uuid
  emailLogId          BigInt             @unique
  userId              String             @db.Uuid
  extractedVendor     String?            @db.VarChar(255)
  extractedAmount     Decimal?           @db.Decimal(15, 2)
  extractedCurrency   String?            @db.Char(3)
  extractedDate       DateTime?          @db.Date
  suggestedCategoryId String?            @db.Uuid
  extractedType       TransactionType?
  extractedNotes      String?            @db.Text
  confidenceScore     Float?             @db.Real
  status              AiExtractionStatus @default(pending)
  confirmedAt         DateTime?          @db.Timestamptz
  createdAt           DateTime           @default(now()) @db.Timestamptz
  updatedAt           DateTime           @updatedAt @db.Timestamptz

  emailLog          EmailLog     @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestedCategory Category?    @relation("SuggestedCategory", fields: [suggestedCategoryId], references: [id], onDelete: SetNull)
  transaction       Transaction?

  @@index([userId])
  @@index([suggestedCategoryId])
  @@index([userId, status])
  @@map("ai_extractions")
}

model RecurringTransaction {
  id                String             @id @default(uuid(7)) @db.Uuid
  userId            String             @db.Uuid
  categoryId        String?            @db.Uuid
  type              TransactionType
  amount            Decimal            @db.Decimal(15, 2)
  currency          String             @default("IDR") @db.Char(3)
  description       String             @db.VarChar(255)
  frequency         RecurringFrequency
  nextDueDate       DateTime           @db.Timestamptz
  lastGeneratedDate DateTime?          @db.Timestamptz
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now()) @db.Timestamptz
  updatedAt         DateTime           @updatedAt @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([userId])
  @@index([categoryId])
  @@index([isActive, nextDueDate])
  @@map("recurring_transactions")
}

model Budget {
  id             String       @id @default(uuid(7)) @db.Uuid
  userId         String       @db.Uuid
  categoryId     String       @db.Uuid
  amount         Decimal      @db.Decimal(15, 2)
  period         BudgetPeriod
  alertThreshold Float        @default(0.8) @db.Real
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, period])
  @@index([userId])
  @@map("budgets")
}

model Bank {
  id             String  @id @default(uuid(7)) @db.Uuid
  name           String  @db.VarChar(100)
  email          String? @db.VarChar(255)
  imageUrl       String
  isSupportEmail Boolean

  bankAccounts BankAccount[]

  @@map("banks")
}

model BankAccount {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @db.Uuid
  bankId    String   @db.Uuid
  balance   Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bank         Bank          @relation(fields: [bankId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, bankId])
  @@map("bank_accounts")
}

// -----------------------------------------------------------
// App tables — Internal (BigInt AUTO_INCREMENT)
// -----------------------------------------------------------

model EmailLog {
  id           BigInt         @id @default(autoincrement())
  inboxId      String         @db.Uuid
  userId       String         @db.Uuid
  fromAddress  String         @db.VarChar(255)
  subject      String?        @db.Text
  rawBody      String?        @db.Text
  status       EmailLogStatus @default(received)
  errorMessage String?        @db.Text
  receivedAt   DateTime       @default(now()) @db.Timestamptz
  processedAt  DateTime?      @db.Timestamptz
  createdAt    DateTime       @default(now()) @db.Timestamptz

  inbox        EmailInbox    @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiExtraction AiExtraction?
  attachments  Attachment[]

  @@index([inboxId])
  @@index([userId])
  @@index([userId, status])
  @@index([receivedAt])
  @@map("email_logs")
}

model Attachment {
  id            BigInt   @id @default(autoincrement())
  transactionId String?  @db.Uuid
  emailLogId    BigInt?
  fileUrl       String   @db.Text
  fileName      String   @db.VarChar(255)
  fileType      String?  @db.VarChar(100)
  fileSize      BigInt?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  emailLog    EmailLog?    @relation(fields: [emailLogId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([emailLogId])
  @@map("attachments")
}
